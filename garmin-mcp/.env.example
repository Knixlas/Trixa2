# Garmin Connect-inloggning (samma som du använder på connect.garmin.com)
GARMIN_EMAIL=din.epost@example.com
GARMIN_PASSWORD=ditt-losenord

# Var OAuth-tokens cachas (default ~/.garminconnect)
GARMIN_TOKEN_DIR=~/.garminconnect

# Supabase (för sync.py – hämtas från https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://vtwqebihrxrufgrzmefe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Valfritt: koppla athlete_profile till en specifik auth.users-rad.
# Lämna tomt så skapas profilen utan user_id (du kan koppla in den senare).
SUPABASE_USER_ID=

# Loggnivå: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
